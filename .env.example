# AgentWorks — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Infrastructure passwords
REDIS_PASSWORD=change-me-to-a-strong-password
POSTGRES_PASSWORD=change-me-to-a-strong-password

# LLM provider keys (at least one required for the engine to work)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: API keys for authenticating clients (comma-separated in config)
# AGENTWORKS_API_KEY=your-api-key-here
