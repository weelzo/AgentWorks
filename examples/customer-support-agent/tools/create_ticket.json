{
  "tool_id": "create_ticket",
  "name": "Create Support Ticket",
  "description": "Create a new support ticket in the ticketing system. Use this when a customer issue has been confirmed and needs to be escalated or tracked for resolution.",
  "version": "1.0.0",
  "endpoint_url": "http://localhost:8001/api/tickets/create",
  "http_method": "POST",
  "ssrf_check_enabled": false,
  "input_schema": {
    "type": "object",
    "properties": {
      "customer_id": {
        "type": "string",
        "description": "The customer ID this ticket is for"
      },
      "type": {
        "type": "string",
        "enum": ["refund", "bug", "feature_request", "general"],
        "description": "The type of support ticket"
      },
      "priority": {
        "type": "string",
        "enum": ["low", "medium", "high", "urgent"],
        "default": "medium"
      },
      "subject": {
        "type": "string",
        "description": "Short summary of the issue"
      },
      "description": {
        "type": "string",
        "description": "Detailed description of the issue and resolution steps"
      },
      "amount": {
        "type": "number",
        "description": "Refund amount in USD (required for refund tickets)"
      }
    },
    "required": ["customer_id", "type", "subject", "description"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "ticket_id": { "type": "string" },
      "status": { "type": "string" },
      "created_at": { "type": "string" }
    }
  },
  "timeout_seconds": 10,
  "owner_team": "support",
  "tags": ["ticketing"],
  "rate_limit": {
    "requests_per_minute": 20,
    "burst_size": 5
  }
}
